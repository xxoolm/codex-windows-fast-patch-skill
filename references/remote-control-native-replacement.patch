+fn remote_control_proxy_env_value() -> Option<(String, String)> {
+    [
+        "HTTPS_PROXY",
+        "https_proxy",
+        "HTTP_PROXY",
+        "http_proxy",
+        "ALL_PROXY",
+        "all_proxy",
+    ]
+    .into_iter()
+    .find_map(|name| {
+        env::var(name)
+            .ok()
+            .map(|value| value.trim().to_string())
+            .filter(|value| !value.is_empty())
+            .map(|value| (name.to_string(), value))
+    })
+}
+
+fn maybe_apply_remote_control_proxy_fallback(websocket_url: &str) -> Option<String> {
+    const MARKER: &str = "remote_control_websocket_proxy_attempt";
+    if let Some((name, value)) = remote_control_proxy_env_value() {
+        info!(
+            websocket_url,
+            proxy_env = %name,
+            proxy = %value,
+            marker = MARKER,
+            "remote control websocket proxy environment already configured"
+        );
+        return Some(value);
+    }
+
+    if env::var(REMOTE_CONTROL_DISABLE_V2RAYN_PROXY_FALLBACK)
+        .ok()
+        .is_some_and(|value| value == "1" || value.eq_ignore_ascii_case("true"))
+    {
+        info!(
+            websocket_url,
+            marker = MARKER,
+            "remote control websocket v2rayN proxy fallback disabled"
+        );
+        return None;
+    }
+
+    let fallback_addr = SocketAddr::from(([127, 0, 0, 1], 10808));
+    match std::net::TcpStream::connect_timeout(
+        &fallback_addr,
+        std::time::Duration::from_millis(300),
+    ) {
+        Ok(stream) => {
+            drop(stream);
+            // The patched tokio-tungstenite fork reads standard proxy env vars.
+            // Set them only for this process, immediately before the remote-control connect.
+            unsafe {
+                env::set_var("HTTPS_PROXY", REMOTE_CONTROL_V2RAYN_PROXY_FALLBACK);
+                env::set_var("HTTP_PROXY", REMOTE_CONTROL_V2RAYN_PROXY_FALLBACK);
+            }
+            info!(
+                websocket_url,
+                proxy = REMOTE_CONTROL_V2RAYN_PROXY_FALLBACK,
+                marker = MARKER,
+                "remote control websocket using local v2rayN proxy fallback"
+            );
+            Some(REMOTE_CONTROL_V2RAYN_PROXY_FALLBACK.to_string())
+        }
+        Err(err) => {
+            warn!(
+                websocket_url,
+                proxy = REMOTE_CONTROL_V2RAYN_PROXY_FALLBACK,
+                marker = MARKER,
+                "remote control websocket proxy fallback unavailable: {err}"
+            );
+            None
+        }
+    }
+}

+async fn load_isolated_remote_control_auth(
+    auth_manager: &AuthManager,
+) -> io::Result<Option<IsolatedRemoteControlAuth>> {
+    let marker = "remote_control_native_remote_json_first";
+    for codex_home in isolated_remote_control_auth_home_candidates(auth_manager) {
+        let remote_json_path = codex_home.join("remote.json");
+        info!(
+            path = %remote_json_path.display(),
+            marker,
+            "checking isolated remote control auth"
+        );
+        match std::fs::read_to_string(&remote_json_path) {
+            Ok(raw) => {
+                let auth = parse_isolated_remote_control_auth(&remote_json_path, &raw)?;
+                if auth.is_some() {
+                    return Ok(auth);
+                }
+            }
+            Err(err) if err.kind() == ErrorKind::NotFound => {}
+            Err(err) => {
+                warn!(
+                    path = %remote_json_path.display(),
+                    marker,
+                    "failed reading isolated remote control auth: {err}"
+                );
+            }
+        }
+
+        let oauth_path = codex_home.join("remote-control-oauth.json");
+        info!(
+            path = %oauth_path.display(),
+            marker = "remote-control-oauth.json",
+            scope = "codex.remote_control.enroll",
+            "remote control enroll token is reserved for enrollment and MFA step-up"
+        );
+    }
+    Ok(None)
+}
+
+fn isolated_remote_control_auth_home_candidates(auth_manager: &AuthManager) -> Vec<PathBuf> {
+    let mut seen = BTreeSet::new();
+    let mut candidates = Vec::new();
+    let mut push = |path: Option<PathBuf>| {
+        let Some(path) = path else {
+            return;
+        };
+        if path.as_os_str().is_empty() {
+            return;
+        }
+        let key = path.to_string_lossy().to_ascii_lowercase();
+        if seen.insert(key) {
+            candidates.push(path);
+        }
+    };
+
+    push(Some(auth_manager.codex_home()));
+    push(env::var_os("CODEX_HOME").map(PathBuf::from));
+    push(env::var_os("USERPROFILE").map(|home| PathBuf::from(home).join(".codex")));
+    push(env::var_os("HOME").map(|home| PathBuf::from(home).join(".codex")));
+    candidates
+}
+
+fn parse_isolated_remote_control_auth(
+    source: &Path,
+    raw: &str,
+) -> io::Result<Option<IsolatedRemoteControlAuth>> {
+    let value: Value = serde_json::from_str(raw).map_err(|err| {
+        io::Error::new(
+            ErrorKind::InvalidData,
+            format!(
+                "failed to parse isolated remote control auth `{}`: {err}",
+                source.display()
+            ),
+        )
+    })?;
+
+    if json_bool(&value, "disabled").unwrap_or(false) {
+        warn!(
+            path = %source.display(),
+            marker = "remote_control_native_remote_json_first",
+            "isolated remote control auth is disabled"
+        );
+        return Ok(None);
+    }
+    if json_bool(&value, "expired").unwrap_or(false) {
+        warn!(
+            path = %source.display(),
+            marker = "remote_control_native_remote_json_first",
+            "isolated remote control auth is expired"
+        );
+        return Ok(None);
+    }
+
+    let access_token = json_string(&value, "access_token")
+        .or_else(|| nested_json_string(&value, "tokens", "access_token"))
+        .ok_or_else(|| {
+            io::Error::new(
+                ErrorKind::InvalidData,
+                format!(
+                    "isolated remote control auth `{}` is missing access_token",
+                    source.display()
+                ),
+            )
+        })?;
+    let account_id = json_string(&value, "account_id")
+        .or_else(|| nested_json_string(&value, "tokens", "account_id"))
+        .or_else(|| json_string(&value, "chatgpt_account_id"))
+        .or_else(|| nested_json_string(&value, "tokens", "chatgpt_account_id"))
+        .ok_or_else(|| {
+            io::Error::new(
+                ErrorKind::InvalidData,
+                format!(
+                    "isolated remote control auth `{}` is missing account_id",
+                    source.display()
+                ),
+            )
+        })?;
+
+    Ok(Some(IsolatedRemoteControlAuth {
+        auth_provider: Arc::new(BearerAuthProvider {
+            token: Some(access_token),
+            account_id: Some(account_id.clone()),
+            is_fedramp_account: json_bool(&value, "is_fedramp_account").unwrap_or(false),
+        }),
+        account_id,
+        source: source.to_path_buf(),
+    }))
+}
+
+fn json_string(value: &Value, key: &str) -> Option<String> {
+    value
+        .get(key)
+        .and_then(Value::as_str)
+        .map(str::trim)
+        .filter(|value| !value.is_empty())
+        .map(str::to_string)
+}
+
+fn nested_json_string(value: &Value, object_key: &str, key: &str) -> Option<String> {
+    value
+        .get(object_key)
+        .and_then(|nested| json_string(nested, key))
+}
+
+fn json_bool(value: &Value, key: &str) -> Option<bool> {
+    value.get(key).and_then(Value::as_bool)
+}
